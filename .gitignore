# ---------------------------------------------------------------------------
# Personal contact info -- local only, never push to GitHub.
# Participants.md holds participant phone numbers; the public site does not
# reference it. Keep your master roster on local disk.
# ---------------------------------------------------------------------------
Participants.md
Participants.private.*

# ---------------------------------------------------------------------------
# Personal Google Maps Takeout dump (saved places, history). Not used by the
# build pipeline. Keep it out of the public repo.
# ---------------------------------------------------------------------------
Takeout/

# ---------------------------------------------------------------------------
# Raw research / narrative source material with personal attribution in the
# filenames. The build pipeline doesn't read it; keep it local-only.
# ---------------------------------------------------------------------------
Collected Location Info/

# ---------------------------------------------------------------------------
# KML Viewer dev workspace. ~100 MB of node_modules; pure dev tooling, not
# part of the trip site. Keep the source if you want, ignore the bulk.
# ---------------------------------------------------------------------------
KML Viewer/node_modules/
KML Viewer/dist/
KML Viewer/.vite/

# ---------------------------------------------------------------------------
# Python build artifacts.
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# ---------------------------------------------------------------------------
# Scratch / temp scripts (one-off helpers prefixed with _, e.g. _check_links.py).
# ---------------------------------------------------------------------------
scripts/_*.py

# ---------------------------------------------------------------------------
# Editor and OS noise.
# ---------------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Build / publish staging directory created by the deploy workflow.
# ---------------------------------------------------------------------------
_publish/

# ---------------------------------------------------------------------------
# PWA artifacts that are regenerated by scripts/build_pwa_*.py on every CI
# build. Not committed; produced fresh into the publish staging dir.
#
# (Keep `assets/icon-source.svg` -- that one IS the source of truth.)
# ---------------------------------------------------------------------------
manifest.webmanifest
service-worker.js
robots.txt
icons/
assets/qr.png
